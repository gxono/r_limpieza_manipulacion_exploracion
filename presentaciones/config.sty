\ExplSyntaxOn
\NewDocumentEnvironment{shake}{ +b }
{
	\text_map_inline:nn { #1 }
	{
		\str_if_eq:nnTF { ##1 } { ~ } { ~ }
		{
			\raisebox{ \fp_eval:n { (rand() - 0.5) * 3 } pt }{ ##1 }
		}
	}
}{}
\ExplSyntaxOff

\def\shaky#1{\begin{shake}#1\end{shake}}




\def\titleitem#1{\par\vspace{0.5em}\textbf{#1}\par}
\def\subtitleitem#1{\textbf{#1}}
\def\quotation#1{\guillemetleft #1\guillemetright}
\def\rscript#1{\lstinline[style=RScript, basicstyle=\normalsize\ttfamily]♪#1♪}




\def\oboxc#1{\hbox to 0pt {\hss#1\hss}}
\ExplSyntaxOn
% :)
\def\asky{
	\hbox~to~1em{
		\hss
		\raise-3pt\oboxc{{\color{unlfce}$\smallsmile$}}
		\oboxc{\rscript{?}}
		\raise1.5pt\oboxc{.~.}
		\hss
	}
}
\ExplSyntaxOff



